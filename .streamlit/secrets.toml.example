# Copy this file to .streamlit/secrets.toml (which IS gitignored) and fill in
# real values. For Streamlit Cloud deploys, paste the same contents into
# the app's Secrets editor in the Streamlit Cloud dashboard.

# --- The Odds API (https://the-odds-api.com) ---
THE_ODDS_API_KEY = "paste_here"

# --- Apify (https://console.apify.com/account/integrations) ---
APIFY_API_TOKEN = "paste_here"

# --- Supabase (https://supabase.com → your project → Settings → API) ---
SUPABASE_URL = "https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_KEY = "paste_service_role_key_here"

# --- LLM provider — pick one ---
LLM_PROVIDER = "anthropic"     # or "google"

# Anthropic (Claude)
ANTHROPIC_API_KEY = "paste_here"
ANTHROPIC_MODEL = "claude-opus-4-5"   # or "claude-sonnet-4-5" for cheaper

# Google (Gemini) — only needed if LLM_PROVIDER = "google"
GOOGLE_API_KEY = "paste_here"
GEMINI_MODEL = "gemini-2.5-pro"
